# Aether environment variables
# Copy this file to `.env` and adjust as needed.

# ---- Server / Proxy ----
# NODE_ENV is set automatically by the dev/start scripts. In production the
# Jellyfin proxy blocks requests to loopback/private network hosts unless they
# are explicitly allowlisted below. In development those hosts are allowed.

# Optional: comma-separated list of Jellyfin hostnames/IPs the proxy may reach
# even in production (useful when hosting Aether behind a reverse proxy that
# talks to Jellyfin on a private network).
# JELLYFIN_ALLOWED_HOSTS=192.168.1.100,media.local,jellyfin.example.com

# Optional: override the port the Express dev server listens on (default 5173).
# PORT=5173
